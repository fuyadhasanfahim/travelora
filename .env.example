# ── Database ────────────────────────────────────────────────────────────
# Neon PostgreSQL Connection String (or any other PostgreSQL service)
DATABASE_URL="postgresql://username:password@hostname:port/dbname?sslmode=require"

# ── Site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Resend (transactional email) ───────────────────────────────────────
# API key for Resend email service
RESEND_API_KEY=""
# The sender email address. Must be a verified domain in Resend (default onboarding domain is onboarding@resend.dev)
RESEND_FROM_EMAIL="Travelora <onboarding@resend.dev>"
# Reply-to email address for customer responses
RESEND_REPLY_TO="support@example.com"
# Admin email where new booking & contact notifications are sent
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# ── Cloudflare Turnstile (bot protection) ──────────────────────────────
# Site key and secret key for Cloudflare Turnstile captcha
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Stripe (payment gateway - prepared, not active) ────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Analytics ──────────────────────────────────────────────────────────
# Google Analytics Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# Meta Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=""
